<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Astro Basics</title>
	</head>
	<body>
		<slot />
	<div id="ab-gate" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(15, 52, 96, 0.98); z-index:999999; color:white; text-align:center; padding-top:15vh; font-family:sans-serif;">
    <div style="max-width:450px; margin:0 auto; padding:30px; border:2px solid #e94560; border-radius:15px; background:#16213e;">
        <div style="font-size:4rem; margin-bottom:20px;">🛡️</div>
        <h2 style="color:#e94560;">Adblock Terdeteksi!</h2>
        <p style="color:#8ea1c3; line-height:1.6;">Mohon matikan Adblock Anda untuk melanjutkan. Iklan membantu kami menjaga server tetap hidup dan software tetap gratis.</p>
        <button onclick="location.reload()" style="background:#e94560; color:white; border:none; padding:12px 25px; border-radius:8px; font-weight:bold; cursor:pointer; width:100%; margin-top:15px;">SAYA SUDAH MATIKAN ADBLOCK</button>
    </div>
</div>

<script>
    async function detectAdBlock() {
        let adBlockEnabled = false;
        const testUrl = 'https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js';
        try {
            await fetch(new Request(testUrl), { mode: 'no-cors' }).catch(() => adBlockEnabled = true);
        } catch (e) {
            adBlockEnabled = true;
        }
        if (adBlockEnabled) {
            const gate = document.getElementById('ab-gate');
            if (gate) {
                gate.style.display = 'block';
                document.body.style.overflow = 'hidden';
            }
        }
    }
    detectAdBlock();
</script>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
