---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content'; 

export async function getStaticPaths() {
  const daftarAplikasi = await getCollection('aplikasi');
  return daftarAplikasi.map((app: CollectionEntry<'aplikasi'>) => ({
    params: { slug: app.id },
    props: { app },
  }));
}

interface Props { app: CollectionEntry<'aplikasi'>; }
const { app } = Astro.props;
const { Content } = await render(app); 
---

<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Download {app.data.title} - Berbagi Aplikasi</title>
    
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f8fafc; margin: 0; padding: 0; color: #334155; }
        .navbar { background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 100%); padding: 15px 40px; display: flex; justify-content: space-between; align-items: center; position: sticky; top: 0; z-index: 100; box-shadow: 0 10px 25px -5px rgba(37, 99, 235, 0.2); }
        .brand { display: flex; align-items: center; gap: 12px; text-decoration: none; }
        .brand-logo { width: 32px; height: 32px; border-radius: 8px; object-fit: contain; background-color: white; padding: 2px;}
        .brand-text { margin: 0; font-size: 22px; font-weight: 800; color: #ffffff; }
        .nav-menu { display: flex; gap: 15px; align-items: center; }
        .nav-link { text-decoration: none; color: #cbd5e1; font-weight: 600; font-size: 14px; padding: 10px 18px; border-radius: 12px; transition: all 0.3s; }
        .nav-link:hover { background-color: rgba(255,255,255,0.15); color: #ffffff; }
        .nav-btn-special { background: linear-gradient(135deg, #14b8a6, #0d9488); color: white; padding: 10px 20px; border-radius: 12px; text-decoration: none; font-weight: 700; font-size: 14px; }
        .container { max-width: 900px; margin: 40px auto; padding: 0 20px; }
        .detail-header { background-color: #ffffff; border-radius: 20px; padding: 35px; display: flex; gap: 35px; border: 1px solid #f1f5f9; box-shadow: 0 10px 25px -5px rgba(37, 99, 235, 0.05); }
        .detail-icon { width: 140px; height: 140px; border-radius: 24px; object-fit: cover; }
        .detail-info { flex-grow: 1; }
        .app-category { align-self: flex-start; font-size: 12px; color: #0284c7; background-color: #e0f2fe; font-weight: 700; padding: 5px 12px; border-radius: 20px; margin-bottom: 12px;}
        .detail-title { margin: 0 0 10px 0; font-size: 28px; font-weight: 800; color: #0f172a; }
        .article-content { background-color: #ffffff; border-radius: 20px; padding: 40px; margin-top: 25px; border: 1px solid #f1f5f9; line-height: 1.8; color: #475569; }
        
        /* GAYA UNTUK FITUR UTAMA */
        .feature-list { list-style: none; padding: 0; }
        .feature-list li { position: relative; padding-left: 28px; margin-bottom: 12px; }
        .feature-list li::before { content: "✓"; position: absolute; left: 0; color: #059669; font-weight: 800; }
        
        /* GAYA BARU UNTUK KELEBIHAN */
        .kelebihan-list { list-style: none; padding: 0; }
        .kelebihan-list li { position: relative; padding-left: 28px; margin-bottom: 12px; }
        .kelebihan-list li::before { content: "★"; position: absolute; left: 0; color: #f59e0b; font-weight: 800; }
        
        .gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin: 20px 0; }
        .gallery img { width: 100%; border-radius: 12px; border: 1px solid #e2e8f0; }
        .req-box { background-color: #f8fafc; border-left: 5px solid #2563eb; padding: 25px; border-radius: 0 12px 12px 0; }
        .btn-download { background: linear-gradient(135deg, #2563eb, #1d4ed8); color: white; padding: 16px 40px; border-radius: 12px; text-decoration: none; font-size: 18px; font-weight: 700; display: inline-flex; align-items: center; gap: 12px; width: 100%; max-width: 400px; justify-content: center;}
    </style>
</head>
<body>
    <div class="navbar">
        <a href="/" class="brand">
            <img src="/favicon.png" alt="Logo" class="brand-logo" onerror="this.src='https://placehold.co/40x40/2563eb/white?text=BA'">
            <h1 class="brand-text">Berbagi Aplikasi</h1>
        </a>
        <div class="nav-menu">
            <a href="/" class="nav-link">Home</a>
            <a href="#" class="nav-link">Jelajahi</a>
            <a href="#" class="nav-btn-special">📝 Request Software</a>
        </div>
    </div>

    <div class="container">
        <div class="detail-header">
            <img src={app.data.gambar || 'https://placehold.co/100x100/ccc/white?text=Ikon'} alt={app.data.title} class="detail-icon">
            <div class="detail-info">
                <div class="app-category">{app.data.kategori}</div>
                <h1 class="detail-title">{app.data.title}</h1>
                <p>OS: {app.data.os} • Ukuran: {app.data.ukuran}</p>
            </div>
        </div>

        <article class="article-content">
            <Content />
            
            {app.data.fungsi && (
                <>
                    <h2>Fitur Utama</h2>
                    <ul class="feature-list">
                        {app.data.fungsi.split('\n').filter((i: string) => i.trim() !== "").map((i: string) => (<li>{i}</li>))}
                    </ul>
                </>
            )}

            {app.data.kelebihan && (
                <>
                    <h2>Kelebihan Aplikasi</h2>
                    <ul class="kelebihan-list">
                        {app.data.kelebihan.split('\n').filter((i: string) => i.trim() !== "").map((i: string) => (<li>{i}</li>))}
                    </ul>
                </>
            )}

            {app.data.screenshots && app.data.screenshots.length > 0 && (
                <>
                    <h2>Tangkapan Layar</h2>
                    <div class="gallery">
                        {app.data.screenshots.map((img: string) => (<img src={img} alt="Screenshot" />))}
                    </div>
                </>
            )}

            <h2>Persyaratan Sistem</h2>
            <div class="req-box">
                <ul>
                    <li><strong>OS Minimum:</strong> {app.data.spesifikasi?.os || "Windows 10/11"}</li>
                    <li><strong>Prosesor:</strong> {app.data.spesifikasi?.prosesor || "-"}</li>
                    <li><strong>RAM:</strong> {app.data.spesifikasi?.ram || "-"}</li>
                    {app.data.spesifikasi?.gpu && <li><strong>Kartu Grafis (GPU):</strong> {app.data.spesifikasi.gpu}</li>}
                    {app.data.spesifikasi?.penyimpanan && <li><strong>Penyimpanan:</strong> {app.data.spesifikasi.penyimpanan}</li>}
                </ul>
            </div>

            <div style="display: flex; flex-direction: column; gap: 15px; align-items: center; margin-top: 40px;">
                {app.data.daftar_download && app.data.daftar_download.map((item: any) => (
                    <a href={'/safelink?url=' + item.link} class="btn-download">⬇️ {item.nama}</a>
                ))}
            </div>
        </article>
    </div>
</body>
</html>