---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content'; 

export async function getStaticPaths() {
  const daftarAplikasi = await getCollection('aplikasi');
  return daftarAplikasi.map((app: CollectionEntry<'aplikasi'>) => ({
    params: { slug: app.id }, // Astro 5 menggunakan app.id
    props: { app },
  }));
}

// Memastikan TypeScript mengenali bentuk data dari CMS
interface Props {
  app: CollectionEntry<'aplikasi'>;
}

const { app } = Astro.props;
// Cara terbaru Astro 5 untuk merender Markdown menjadi HTML
const { Content } = await render(app); 
---

<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Download {app.data.title} - Berbagi Aplikasi</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f8fafc; margin: 0; padding: 0; color: #334155; }
        
        /* NAVBAR GRADASI PREMIUM (SAMA DENGAN INDEX) */
        .navbar { 
            background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 100%); 
            padding: 15px 40px; border-bottom: 1px solid rgba(255,255,255,0.1);
            display: flex; justify-content: space-between; align-items: center; 
            position: sticky; top: 0; z-index: 100; box-shadow: 0 10px 25px -5px rgba(37, 99, 235, 0.2); 
        }
        .brand { display: flex; align-items: center; gap: 12px; text-decoration: none; }
        .brand-logo { width: 32px; height: 32px; border-radius: 8px; object-fit: contain; background-color: white; padding: 2px;}
        .brand-text { margin: 0; font-size: 22px; font-weight: 800; color: #ffffff; letter-spacing: -0.5px; }
        
        .nav-menu { display: flex; gap: 15px; align-items: center; }
        .nav-link { text-decoration: none; color: #cbd5e1; font-weight: 600; font-size: 14px; padding: 10px 18px; border-radius: 12px; transition: all 0.3s; }
        .nav-link:hover { background-color: rgba(255,255,255,0.15); color: #ffffff; }
        
        .nav-btn-special { background: linear-gradient(135deg, #14b8a6, #0d9488); color: white; padding: 10px 20px; border-radius: 12px; text-decoration: none; font-weight: 700; font-size: 14px; transition: transform 0.3s, box-shadow 0.3s; }
        .nav-btn-special:hover { transform: translateY(-2px); box-shadow: 0 4px 12px rgba(20, 184, 166, 0.4); }

        /* KONTEN DETAIL APLIKASI */
        .container { max-width: 900px; margin: 40px auto; padding: 0 20px; }
        .detail-header { background-color: #ffffff; border-radius: 20px; padding: 35px; display: flex; gap: 35px; border: 1px solid #f1f5f9; box-shadow: 0 10px 25px -5px rgba(37, 99, 235, 0.05); }
        .detail-icon { width: 140px; height: 140px; border-radius: 24px; object-fit: cover; }
        .detail-info { flex-grow: 1; display: flex; flex-direction: column; justify-content: center; }
        .app-category { align-self: flex-start; font-size: 12px; color: #0284c7; background-color: #e0f2fe; font-weight: 700; padding: 5px 12px; border-radius: 20px; margin-bottom: 12px;}
        .detail-title { margin: 0 0 10px 0; font-size: 28px; font-weight: 800; color: #0f172a; }
        .detail-meta { color: #64748b; font-size: 14px; font-weight: 500; display: flex; gap: 15px; }
        .article-content { background-color: #ffffff; border-radius: 20px; padding: 40px; margin-top: 25px; border: 1px solid #f1f5f9; line-height: 1.8; color: #475569; font-size: 16px; }
        .article-content h2 { color: #0f172a; font-weight: 800; font-size: 22px; margin: 35px 0 15px 0; border-bottom: 2px solid #f1f5f9; padding-bottom: 10px;}
        .article-content h3 { color: #1e293b; font-weight: 700; font-size: 18px; margin: 25px 0 10px 0; }
        .summary-text { font-size: 18px; font-weight: 500; color: #334155; margin-bottom: 25px; }
        .feature-list { list-style: none; padding: 0; margin: 0 0 25px 0; }
        .feature-list li { position: relative; padding-left: 28px; margin-bottom: 12px; }
        .feature-list li::before { content: "✓"; position: absolute; left: 0; top: 0; color: #059669; font-weight: 800; }
        .gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin: 20px 0 35px 0; }
        .gallery img { width: 100%; border-radius: 12px; border: 1px solid #e2e8f0; }
        .req-box { background-color: #f8fafc; border-left: 5px solid #2563eb; padding: 25px; border-radius: 0 12px 12px 0; margin-bottom: 30px;}
        .req-box ul { margin: 0; padding-left: 20px; display: flex; flex-direction: column; gap: 10px; }
        .btn-download { background: linear-gradient(135deg, #2563eb, #1d4ed8); color: white; padding: 16px 40px; border-radius: 12px; text-decoration: none; font-size: 18px; font-weight: 700; display: inline-flex; align-items: center; gap: 12px; margin-top: 20px;}
    </style>
</head>
<body>
    <div class="navbar">
        <a href="/" class="brand">
            <img src="/logo.png" alt="Logo" class="brand-logo" onerror="this.src='https://placehold.co/40x40/2563eb/white?text=BA'">
            <h1 class="brand-text">Berbagi Aplikasi</h1>
        </a>
        
        <div class="nav-menu">
            <a href="/" class="nav-link">Home</a>
            <a href="#" class="nav-link">Jelajahi</a>
            <a href="#" class="nav-btn-special">📝 Request Software</a>
        </div>
    </div>

    <div class="container">
        <div class="detail-header">
            <img src={app.data.gambar || 'https://placehold.co/100x100/ccc/white?text=Ikon'} alt={app.data.title} class="detail-icon">
            <div class="detail-info">
                <div class="app-category">{app.data.kategori}</div>
                <h1 class="detail-title">{app.data.title}</h1>
                <div class="detail-meta">
                    <span>OS: {app.data.os}</span> • <span>Ukuran: {app.data.ukuran}</span>
                </div>
            </div>
        </div>

        <article class="article-content">
            <div class="summary-text">{app.data.ringkasan}</div>
            
            <h2>Informasi Perangkat Lunak</h2>
            <Content />
            
            <h2>Fitur & Keunggulan Utama</h2>
            
            <h3>Fungsi Aplikasi</h3>
            <ul class="feature-list">
                {(app.data.fungsi || "").split('\n').filter(item => item.trim() !== "").map((item: string) => ( 
                    <li>{item}</li> 
                ))}
            </ul>

            <h3>Kelebihan</h3>
            <ul class="feature-list">
                {(app.data.kelebihan || "").split('\n').filter(item => item.trim() !== "").map((item: string) => ( 
                    <li>{item}</li> 
                ))}
            </ul>

            <h2>Tangkapan Layar</h2>
            <div class="gallery">
                {(app.data.screenshots || []).map((img: string) => ( <img src={img} alt="Screenshot" loading="lazy" /> ))}
            </div>

            <h2>Persyaratan Sistem Minimum</h2>
            <div class="req-box">
                <ul>
                    <li><strong>OS Minimum:</strong> {app.data.spesifikasi?.os || "-"}</li>
                    <li><strong>Prosesor:</strong> {app.data.spesifikasi?.prosesor || "-"}</li>
                    <li><strong>RAM:</strong> {app.data.spesifikasi?.ram || "-"}</li>
                    {app.data.spesifikasi?.gpu && (<li><strong>Kartu Grafis:</strong> {app.data.spesifikasi.gpu}</li>)}
                    {app.data.spesifikasi?.penyimpanan && (<li><strong>Penyimpanan:</strong> {app.data.spesifikasi.penyimpanan}</li>)}
                    
                </ul>
            </div>

            <div style="display: flex; flex-direction: column; gap: 15px; align-items: center; margin-top: 30px;">
                {app.data.daftar_download && app.data.daftar_download.map((item: {nama: string, link: string}) => (
                    <a href={'/safelink?url=' + item.link} class="btn-download" style="width: 100%; max-width: 400px; justify-content: center;">
                        ⬇️ {item.nama}
                    </a>
                ))}

                {!app.data.daftar_download && (
                    <div style="color: #ef4444; font-weight: bold;">Tautan unduhan belum tersedia.</div>
                )}
            </div>
        </article>
    </div>
</body>
</html>