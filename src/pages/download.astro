---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Securing Your Download - Berbagi Aplikasi">
    <main class="safelink-container">
        <div class="scanner-box">
            <div id="scan-ui">
                <div class="shield-icon">🛡️</div>
                <h1 id="status-text">Memulai Pemindaian...</h1>
                <div class="progress-container">
                    <div id="progress-bar"></div>
                </div>
                <p id="detail-text">Menghubungkan ke database keamanan...</p>
            </div>

            <div class="ad-placeholder">
                <p class="ad-label">ADVERTISING</p>
                <div id="ad-native-safelink">
                    </div>
            </div>

            <div id="download-area" class="hidden">
                <div class="safe-badge">✅ File Terverifikasi Aman (No Threats)</div>
                <p>Klik tombol di bawah untuk menuju link download terakhir.</p>
                <a href="#" id="final-link" class="download-btn">DOWNLOAD SEKARANG</a>
            </div>
        </div>

        <div id="ad-social-bar">
            </div>
    </main>
</Layout>

<style>
    .safelink-container { min-height: 100vh; display: flex; align-items: center; justify-content: center; background: #0f3460; padding: 20px; font-family: system-ui, sans-serif; }
    .scanner-box { background: #1a1a2e; padding: 40px; border-radius: 20px; box-shadow: 0 20px 50px rgba(0,0,0,0.5); text-align: center; max-width: 500px; width: 100%; border: 2px solid #2ecc71; }
    
    .shield-icon { font-size: 4rem; margin-bottom: 20px; animation: pulse 2s infinite; }
    @keyframes pulse { 0% { transform: scale(1); } 50% { transform: scale(1.1); } 100% { transform: scale(1); } }
    
    .progress-container { background: #16213e; height: 12px; border-radius: 10px; margin: 20px 0; overflow: hidden; }
    #progress-bar { height: 100%; width: 0%; background: #2ecc71; transition: 0.1s linear; box-shadow: 0 0 15px #2ecc71; }
    
    #status-text { font-size: 1.2rem; color: #fff; margin-bottom: 5px; }
    #detail-text { color: #8ea1c3; font-size: 0.9rem; margin-bottom: 20px; }
    
    .hidden { display: none !important; }
    .safe-badge { display: inline-block; background: rgba(46, 204, 113, 0.2); color: #2ecc71; padding: 10px 20px; border-radius: 8px; font-weight: bold; margin-bottom: 20px; border: 1px solid #2ecc71; }
    
    .download-btn { display: inline-block; background: #2ecc71; color: #1a1a2e; padding: 15px 30px; border-radius: 10px; text-decoration: none; font-weight: 900; font-size: 1.2rem; transition: 0.3s; width: 100%; box-sizing: border-box; }
    .download-btn:hover { background: #27ae60; transform: translateY(-3px); box-shadow: 0 10px 20px rgba(46, 204, 113, 0.3); }

    .ad-placeholder { margin: 25px 0; min-height: 100px; background: rgba(255,255,255,0.05); border-radius: 10px; padding: 10px; border: 1px dashed #444; }
    .ad-label { font-size: 10px; color: #888; margin-bottom: 5px; letter-spacing: 1px; }
</style>

<script>
    // Menangkap parameter ?url= dari link (misal: /download?url=https://t.me/link-file)
    document.addEventListener('DOMContentLoaded', () => {
        const urlParams = new URLSearchParams(window.location.search);
        const targetUrl = urlParams.get('url');
        const finalBtn = document.getElementById('final-link') as HTMLAnchorElement;

        let progress = 0;
        const bar = document.getElementById('progress-bar');
        const status = document.getElementById('status-text');
        const detail = document.getElementById('detail-text');
        const downloadArea = document.getElementById('download-area');
        const scanUI = document.getElementById('scan-ui');

        const messages = [
            "Mencari database malware...",
            "Memindai struktur file...",
            "Memverifikasi tanda tangan digital...",
            "Menyiapkan link unduhan..."
        ];

        // Animasi berjalan selama sekitar 8 detik
        const interval = setInterval(() => {
            progress += 1;
            if (bar) bar.style.width = progress + "%";
            
            if (progress % 25 === 0) {
                if (detail) detail.innerText = messages[Math.floor(progress/25) - 1] || "Selesai!";
            }

            if (progress >= 100) {
                clearInterval(interval);
                if (status) status.innerText = "Pemindaian Selesai!";
                if (detail) detail.innerText = "Sistem aman.";
                
                setTimeout(() => {
                    if (scanUI) scanUI.classList.add('hidden');
                    if (downloadArea) downloadArea.classList.remove('hidden');
                    // Set link asli ke tombol final
                    if (finalBtn && targetUrl) finalBtn.href = targetUrl;
                }, 800);
            }
        }, 80); 
    });
</script>