---
// Halaman Safelink / Gateway - Vibrant Light Mode + Hidden Ad Placements
---

<html lang="id">
<head>
    <title>Menyiapkan Unduhan... - Berbagi Aplikasi</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f8fafc; margin: 0; padding: 0; color: #334155; }
        
        .navbar { 
            background-color: #ffffff; padding: 15px 40px; border-bottom: 1px solid #e2e8f0; border-top: 4px solid #2563eb; 
            display: flex; justify-content: space-between; align-items: center; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05); 
        }
        .brand { display: flex; align-items: center; gap: 12px; text-decoration: none; }
        .brand-logo { width: 28px; height: 28px; border-radius: 6px; object-fit: contain; }
        .brand-text { margin: 0; font-size: 24px; font-weight: 800; background: linear-gradient(135deg, #2563eb, #14b8a6); -webkit-background-clip: text; -webkit-text-fill-color: transparent; letter-spacing: -0.5px; }

        .container { max-width: 800px; margin: 40px auto; padding: 0 20px; display: flex; flex-direction: column; gap: 25px; }
        
        /* KOTAK IKLAN (Disembunyikan) */
        .ad-space { 
            display: none; /* Menyembunyikan iklan dari pengunjung */
            background-color: #f1f5f9; border: 2px dashed #cbd5e1; border-radius: 16px; height: 120px; 
            align-items: center; justify-content: center; color: #94a3b8; font-weight: 600; 
            font-size: 14px; text-transform: uppercase; letter-spacing: 1px;
        }

        .gateway-box { 
            background-color: #ffffff; border-radius: 20px; padding: 40px; text-align: center;
            border: 1px solid #f1f5f9; box-shadow: 0 10px 25px -5px rgba(37, 99, 235, 0.05); 
        }
        .gateway-box h2 { margin-top: 0; color: #0f172a; font-weight: 800; font-size: 24px; }
        .gateway-box p { color: #64748b; font-size: 16px; margin-bottom: 20px; }
        
        .timer-text { font-size: 64px; font-weight: 800; color: #2563eb; margin: 30px 0; text-shadow: 0 4px 10px rgba(37, 99, 235, 0.2); }

        .btn-final { 
            display: none; 
            background: linear-gradient(135deg, #14b8a6, #0d9488); color: white; padding: 16px 40px; 
            border-radius: 12px; text-decoration: none; font-size: 18px; font-weight: 700; 
            transition: all 0.3s ease; box-shadow: 0 4px 12px rgba(20, 184, 166, 0.3); 
            margin: 20px auto; width: fit-content;
        }
        .btn-final:hover { transform: translateY(-3px); box-shadow: 0 8px 20px rgba(20, 184, 166, 0.4); }
    </style>
</head>
<body>

    <div class="navbar">
        <a href="/" class="brand">
            <img src="/logo.png" alt="Logo Berbagi Aplikasi" class="brand-logo" onerror="this.src='https://placehold.co/40x40/2563eb/white?text=BA'">
            <h1 class="brand-text">Berbagi Aplikasi</h1>
        </a>
    </div>

    <div class="container">
        
        <div class="ad-space">Slot Iklan Adsterra Atas (728x90)</div>

        <div class="gateway-box">
            <h2>Menyiapkan Tautan Unduhan Anda...</h2>
            <p>Sistem kami sedang memeriksa keamanan file. Harap tunggu di halaman ini.</p>
            
            <div class="timer-text" id="countdown-timer">10</div>
            
            <a href="https://drive.google.com/file/d/CONTOH_LINK_FILE_KAMU/view" class="btn-final" id="final-button" target="_blank">
                Lanjutkan ke File Anda
            </a>
        </div>

        <div class="ad-space">Slot Iklan Adsterra Bawah (728x90)</div>

    </div>

    <script>
        let timeLeft = 10; 
        const timerElement = document.getElementById('countdown-timer');
        const buttonElement = document.getElementById('final-button');

        if (timerElement && buttonElement) {
            const countdownInterval = setInterval(function() {
                timeLeft--; 
                timerElement.textContent = timeLeft.toString(); 

                if (timeLeft <= 0) {
                    clearInterval(countdownInterval); 
                    timerElement.style.display = 'none'; 
                    buttonElement.style.display = 'inline-block'; 
                }
            }, 1000);
        }
    </script>

</body>
</html>