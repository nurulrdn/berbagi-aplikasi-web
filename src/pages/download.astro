---
// Halaman Safelink Khusus - Tidak terikat dengan Layout lain agar desain aman
---
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Securing Your Download - Berbagi Aplikasi</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        body { 
            margin: 0; 
            padding: 20px;
            font-family: 'Inter', sans-serif; 
            background-color: #0f172a; /* Biru Gelap Profesional */
            color: white; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            min-height: 100vh; 
            box-sizing: border-box;
        }
        .scanner-box { 
            background: #1e293b; 
            padding: 40px; 
            border-radius: 20px; 
            text-align: center; 
            max-width: 450px; 
            width: 100%; 
            border: 2px solid #10b981; /* Hijau Antivirus */
            box-shadow: 0 15px 35px rgba(0,0,0,0.5); 
        }
        .icon { font-size: 4.5rem; margin-bottom: 15px; animation: pulse 2s infinite; }
        @keyframes pulse { 0% { transform: scale(1); } 50% { transform: scale(1.1); } 100% { transform: scale(1); } }
        
        .progress-bg { background: #0f172a; height: 12px; border-radius: 10px; margin: 25px 0; overflow: hidden; }
        #progress-bar { height: 100%; width: 0%; background: #10b981; transition: 0.1s linear; box-shadow: 0 0 10px #10b981; }
        
        .ad-placeholder { margin: 25px 0; min-height: 100px; background: rgba(255,255,255,0.05); border-radius: 12px; padding: 15px; border: 1px dashed #475569; }
        .ad-label { font-size: 10px; color: #94a3b8; margin-bottom: 8px; letter-spacing: 1.5px; }
        
        .safe-badge { background: rgba(16, 185, 129, 0.15); color: #10b981; padding: 12px; border-radius: 8px; font-weight: 800; margin-bottom: 20px; border: 1px solid #10b981; }
        .download-btn { display: block; background: #10b981; color: #0f172a; padding: 16px; border-radius: 12px; text-decoration: none; font-weight: 800; font-size: 1.1rem; transition: 0.3s; }
        .download-btn:hover { background: #059669; transform: translateY(-3px); }
    </style>
</head>
<body>

    <div class="scanner-box">
        <div id="scan-view">
            <div class="icon">🛡️</div>
            <h2 style="margin:0 0 10px 0;">Memindai Keamanan...</h2>
            <div class="progress-bg">
                <div id="progress-bar"></div>
            </div>
            <p id="scan-status" style="color: #94a3b8; font-size: 0.95rem;">Menghubungkan ke server keamanan...</p>
        </div>

        <div class="ad-placeholder">
            <p class="ad-label">ADVERTISING</p>
            <div id="ad-native-safelink">
                </div>
        </div>

        <div id="ready-view" style="display: none;">
            <div class="safe-badge">✅ FILE AMAN DARI VIRUS</div>
            <p style="color: #cbd5e1; margin-bottom: 20px; font-size: 0.95rem;">Silakan klik tombol di bawah untuk mengunduh file Anda dengan kecepatan penuh.</p>
            <a href="#" id="final-link" class="download-btn">DOWNLOAD SEKARANG</a>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Mengambil URL asli dari parameter (?url=...)
            const urlParams = new URLSearchParams(window.location.search);
            const targetUrl = urlParams.get('url') || '/'; // Default ke home jika kosong
            
            const progressBar = document.getElementById('progress-bar');
            const scanStatus = document.getElementById('scan-status');
            const finalLink = document.getElementById('final-link') as HTMLAnchorElement;
            const scanView = document.getElementById('scan-view');
            const readyView = document.getElementById('ready-view');

            let progress = 0;
            const statusMessages = [
                "Mencari database malware...",
                "Memeriksa struktur file installer...",
                "Memverifikasi tanda tangan digital...",
                "Menyiapkan jalur unduhan..."
            ];

            // Simulasi proses berjalan selama ~8 detik
            const scanInterval = setInterval(() => {
                progress += 1;
                if (progressBar) progressBar.style.width = progress + "%";
                
                // Ganti teks setiap 25%
                if (progress % 25 === 0 && scanStatus) {
                    scanStatus.innerText = statusMessages[Math.floor(progress/25) - 1] || "Selesai!";
                }

                // Jika sudah 100%
                if (progress >= 100) {
                    clearInterval(scanInterval);
                    setTimeout(() => {
                        if (scanView) scanView.style.display = 'none';
                        if (readyView) readyView.style.display = 'block';
                        if (finalLink) finalLink.href = targetUrl;
                    }, 500); // Jeda setengah detik biar mulus
                }
            }, 80); 
        });
    </script>
</body>
</html>