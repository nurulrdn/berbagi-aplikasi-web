---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Securing Your File - Berbagi Aplikasi">
    <main style="min-height:90vh; display:flex; align-items:center; justify-content:center; background:#0f3460; padding:20px;">
        <div style="background:#1a1a2e; padding:40px; border-radius:20px; text-align:center; max-width:450px; width:100%; border:2px solid #2ecc71; box-shadow:0 15px 35px rgba(0,0,0,0.4);">
            
            <div id="scan-view">
                <div style="font-size:4rem; margin-bottom:15px;">🛡️</div>
                <h2 style="color:#fff; margin-bottom:10px;">Memeriksa Keamanan...</h2>
                <div style="background:#16213e; height:10px; border-radius:10px; margin:20px 0; overflow:hidden;">
                    <div id="p-bar" style="height:100%; width:0%; background:#2ecc71; transition:0.1s linear;"></div>
                </div>
                <p id="p-status" style="color:#8ea1c3; font-size:0.9rem;">Menghubungkan ke database virus...</p>
            </div>

            <div style="margin:20px 0; min-height:100px; background:rgba(255,255,255,0.03); border-radius:10px; padding:10px;">
                <p style="font-size:10px; color:#555; margin-bottom:5px;">ADVERTISING</p>
                <div id="ad-native-placeholder">
                    </div>
            </div>

            <div id="ready-view" style="display:none;">
                <div style="background:rgba(46, 204, 113, 0.1); color:#2ecc71; padding:10px; border-radius:8px; border:1px solid #2ecc71; margin-bottom:20px; font-weight:bold;">
                    ✅ File Aman: Tidak Ada Ancaman
                </div>
                <a href="#" id="dl-link" style="display:block; background:#2ecc71; color:#1a1a2e; padding:15px; border-radius:10px; text-decoration:none; font-weight:bold; font-size:1.1rem;">DOWNLOAD SEKARANG</a>
            </div>
        </div>
    </main>
</Layout>

<script>
    const urlParams = new URLSearchParams(window.location.search);
    const target = urlParams.get('url');
    const bar = document.getElementById('p-bar');
    const status = document.getElementById('p-status');
    const dlBtn = document.getElementById('dl-link') as HTMLAnchorElement;

    let width = 0;
    const labels = ["Memindai Malware...", "Mengecek Ransomware...", "Verifikasi File...", "Hampir Selesai..."];
    
    const timer = setInterval(() => {
        width++;
        if(bar) bar.style.width = width + '%';
        if(width % 25 === 0) status!.innerText = labels[Math.floor(width/25)-1] || "Selesai!";
        
        if(width >= 100) {
            clearInterval(timer);
            document.getElementById('scan-view')!.style.display = 'none';
            document.getElementById('ready-view')!.style.display = 'block';
            if(dlBtn && target) dlBtn.href = target;
        }
    }, 70); // Sekitar 7 detik scan
</script>