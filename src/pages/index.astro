---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content'; 

const daftarAplikasi = (await getCollection('aplikasi')).reverse();
const semuaKategori = [...new Set(daftarAplikasi.map((app: CollectionEntry<'aplikasi'>) => app.data.kategori))];

const appsPerPage = 10;
const displayedApps = daftarAplikasi.slice(0, appsPerPage);
---

<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Berbagi Aplikasi - Download Software Gratis</title>
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f8fafc; margin: 0; padding: 0; color: #334155; }
        
        /* NAVBAR UTAMA */
        .navbar { background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 100%); padding: 15px 40px; display: flex; justify-content: space-between; align-items: center; position: sticky; top: 0; z-index: 100; box-shadow: 0 10px 25px -5px rgba(37, 99, 235, 0.2); flex-wrap: wrap; }
        .brand { display: flex; align-items: center; gap: 12px; text-decoration: none; }
        .brand-logo { width: 32px; height: 32px; border-radius: 8px; object-fit: contain; background-color: white; padding: 2px;}
        .brand-text { margin: 0; font-size: 22px; font-weight: 800; color: #ffffff; }
        
        /* 📱 TOMBOL MENU HP (Sekarang Rapi & Elegan) */
        .mobile-menu-btn { 
            display: none; 
            background: transparent; 
            color: #ffffff; 
            font-size: 28px; 
            cursor: pointer; 
            padding: 5px; 
            border: none;
            line-height: 1;
            transition: 0.3s;
        }
        
        .nav-menu { display: flex; gap: 15px; align-items: center; }
        .nav-btn-special { background: linear-gradient(135deg, #14b8a6, #0d9488); color: white; padding: 10px 20px; border-radius: 12px; text-decoration: none; font-weight: 700; font-size: 14px; text-align: center; }
        .search-bar { padding: 12px 20px; width: 260px; border: 1px solid rgba(255,255,255,0.2); border-radius: 25px; outline: none; background-color: rgba(255,255,255,0.05); color: white; }
        
        /* Menu Ekstra di HP (Sistem Operasi & Kategori) */
        .mobile-extra-menu { display: none; width: 100%; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 20px; margin-top: 10px; }
        .mobile-link { background: rgba(255,255,255,0.1); color: #e2e8f0; text-decoration: none; padding: 10px 15px; border-radius: 8px; font-size: 13px; font-weight: 600; text-align: center; flex: 1 1 auto; transition: 0.2s;}
        .mobile-link:hover { background: rgba(255,255,255,0.2); color: white; }

        /* LAYOUT KONTEN */
        .main-layout { display: flex; max-width: 1100px; margin: 30px auto; padding: 0 20px; gap: 40px; }
        .sidebar { width: 220px; flex-shrink: 0; }
        .menu-title { font-size: 12px; color: #64748b; font-weight: 800; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 15px; }
        .menu-list { list-style: none; padding: 0; margin: 0 0 35px 0; }
        .menu-list a { text-decoration: none; color: #475569; display: block; padding: 10px 14px; border-radius: 8px; font-weight: 600; font-size: 15px; transition: all 0.2s;}
        .menu-list a:hover { background-color: #eff6ff; color: #2563eb; transform: translateX(5px); }
        .content { flex-grow: 1; }
        
        .hero-banner { background: linear-gradient(135deg, #eff6ff 0%, #e0f2fe 100%); border: 1px solid #bfdbfe; border-radius: 20px; padding: 35px 40px; margin-bottom: 35px; }
        .hero-title { margin: 0 0 10px 0; font-size: 26px; font-weight: 800; color: #1e3a8a; }
        .app-item { background-color: #ffffff; border-radius: 16px; padding: 20px; border: 1px solid #f1f5f9; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.03); text-decoration: none; display: flex; align-items: flex-start; gap: 24px; transition: all 0.3s; margin-bottom: 20px;}
        .app-item:hover { transform: translateY(-3px); box-shadow: 0 10px 15px -3px rgba(37,99,235,0.1); border-color: #bfdbfe; }
        .app-image { width: 90px; height: 90px; object-fit: cover; border-radius: 16px; flex-shrink: 0; }
        .app-text-block { display: flex; flex-direction: column; flex-grow: 1; }
        .app-category { align-self: flex-start; font-size: 11px; color: #0284c7; background-color: #e0f2fe; font-weight: 700; padding: 4px 10px; border-radius: 20px; margin-bottom: 10px; }
        .app-title { font-size: 19px; color: #0f172a; font-weight: 700; margin: 0 0 8px 0; }
        
        .pagination-container { display: flex; justify-content: center; gap: 15px; margin-top: 30px; }
        .btn-page { padding: 10px 20px; background: #ffffff; border: 1px solid #cbd5e1; border-radius: 10px; color: #475569; font-weight: 600; cursor: pointer; transition: 0.3s; }
        .btn-page:hover { background: #f1f5f9; border-color: #94a3b8; }
        .btn-page-active { background: #2563eb; color: white; border-color: #2563eb; }

        .ad-banner { background: #ffffff; border: 1px dashed #cbd5e1; border-radius: 16px; padding: 15px; text-align: center; margin-bottom: 25px; }
        .ad-label { font-size: 10px; color: #94a3b8; letter-spacing: 1px; margin: 0 0 10px 0; }

        /* 📱 CSS KHUSUS HP YANG SUDAH DI-PERMAK */
        @media (max-width: 768px) {
            .navbar { padding: 15px 20px; }
            .mobile-menu-btn { display: block !important; }
            
            .nav-menu { display: none; width: 100%; flex-direction: column; margin-top: 15px; gap: 15px; }
            .nav-menu.active { display: flex !important; }
            
            .nav-btn-special { width: 100%; box-sizing: border-box; }
            .search-bar { width: 100%; box-sizing: border-box; }
            
            /* Tampilkan menu ekstra di dalam Navbar, sembunyikan yang di Sidebar */
            .mobile-extra-menu { display: block; }
            .desktop-sidebar-menu { display: none; }
            
            .main-layout { flex-direction: column; padding: 0 15px; gap: 20px; }
            .sidebar { width: 100%; }
            .hero-banner { padding: 25px 20px; text-align: center; }
            .app-item { flex-direction: column; align-items: center; text-align: center; gap: 15px; }
            .app-category { align-self: center; }
        }
    </style>
</head>
<body>
    <div class="navbar">
        <a href="/" class="brand">
            <img src="/logo.png" alt="Logo" class="brand-logo" onerror="this.src='https://placehold.co/40x40/2563eb/white?text=BA'">
            <h1 class="brand-text">Berbagi Aplikasi</h1>
        </a>
        
        <button class="mobile-menu-btn" id="mobileBtn">☰</button>

        <div class="nav-menu" id="navMenu">
            <a href="/request" class="nav-btn-special">📝 Request Software</a>
            <input type="text" id="searchInput" class="search-bar" placeholder="Cari software...">
            
            <div class="mobile-extra-menu">
                <div style="font-size: 11px; color: #94a3b8; font-weight: 800; letter-spacing: 1px; margin-bottom: 12px;">SISTEM OPERASI</div>
                <div style="display: flex; gap: 10px; margin-bottom: 25px;">
                    <a href="/os/windows" class="mobile-link">Windows</a>
                    <a href="/os/macos" class="mobile-link">macOS</a>
                    <a href="/os/linux" class="mobile-link">Linux</a>
                </div>
                
                <div style="font-size: 11px; color: #94a3b8; font-weight: 800; letter-spacing: 1px; margin-bottom: 12px;">KATEGORI UTAMA</div>
                <div style="display: flex; flex-wrap: wrap; gap: 10px;">
                    {semuaKategori.map((kategori) => (
                        <a href={'/kategori/' + (kategori as string).toLowerCase().replace(/\s+/g, '-')} class="mobile-link">{kategori}</a>
                    ))}
                </div>
            </div>
        </div>
    </div>
    
    <div class="main-layout">
        <div class="sidebar">
            <div class="desktop-sidebar-menu">
                <div class="menu-title">Sistem Operasi</div>
                <ul class="menu-list">
                    <li><a href="/os/windows">Windows</a></li>
                    <li><a href="/os/macos">macOS</a></li>
                    <li><a href="/os/linux">Linux</a></li>
                </ul>
                <div class="menu-title" style="margin-top: 25px;">Kategori Utama</div>
                <ul class="menu-list">
                    {semuaKategori.map((kategori) => (
                        <li><a href={'/kategori/' + (kategori as string).toLowerCase().replace(/\s+/g, '-')}>{kategori}</a></li>
                    ))}
                </ul>
            </div>

            <div style="margin-top: 20px;" class="ad-banner">
                <p class="ad-label">ADVERTISING</p>
            </div>
        </div>

        <div class="content">
            <div class="hero-banner">
                <h2 class="hero-title">Temukan Software PC Terbaik</h2>
                <p style="color: #475569; margin: 0;">Pusat unduhan aplikasi gratis yang aman dan mudah di-instal.</p>
            </div>

            <div class="ad-banner">
                <p class="ad-label">ADVERTISING</p>
            </div>
            
            <div id="appList">
                {displayedApps.map((app: any) => (
                    <a href={'/' + (app.slug || app.id)} class="app-item" data-title={app.data.title.toLowerCase()}>
                        <img src={app.data.gambar || 'https://placehold.co/100x100/ccc/white?text=Ikon'} alt={app.data.title} class="app-image">
                        <div class="app-text-block">
                            <div class="app-category">{app.data.kategori}</div>
                            <h3 class="app-title">{app.data.title}</h3>
                            <p style="font-size: 14px; color: #475569; margin: 0 0 10px 0;">{app.data.ringkasan}</p>
                            <div style="font-size: 13px; color: #64748b; font-weight: 600;">
                                <span style="background: #f1f5f9; padding: 4px 10px; border-radius: 6px;">{app.data.os}</span>
                                <span style="margin-left: 10px;">{app.data.ukuran}</span>
                            </div>
                        </div>
                    </a>
                ))}
            </div>

            <div class="pagination-container">
                <button class="btn-page" disabled style="opacity: 0.5;">&laquo; Prev</button>
                <button class="btn-page btn-page-active">1</button>
                <button class="btn-page">Next &raquo;</button>
            </div>
        </div>
    </div>

    <div id="ab-gate" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(15, 23, 42, 0.98); z-index:999999; color:white; text-align:center; padding-top:15vh;">
        <div style="max-width:450px; margin:0 auto; padding:40px; background:#ffffff; border-radius:20px; box-shadow:0 25px 50px -12px rgba(0, 0, 0, 0.5);">
            <div style="font-size:4rem; margin-bottom:20px;">🛑</div>
            <h2 style="color:#0f172a; margin: 0 0 15px 0;">Adblock Terdeteksi!</h2>
            <p style="color:#475569; line-height:1.6; margin-bottom: 25px;">Akses Terkunci. Mohon matikan ekstensi Adblock Anda untuk melanjutkan. Iklan membantu kami menjaga server tetap hidup.</p>
            <button onclick="location.reload()" style="background:#2563eb; color:white; border:none; padding:15px 30px; border-radius:12px; font-weight:bold; cursor:pointer; width:100%; font-size: 15px;">SAYA SUDAH MATIKAN ADBLOCK</button>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // SCRIPT TOMBOL MENU (Ubah Ikon Elegan)
            const mobileBtn = document.getElementById('mobileBtn');
            const navMenu = document.getElementById('navMenu');
            
            if (mobileBtn && navMenu) {
                mobileBtn.addEventListener('click', () => {
                    navMenu.classList.toggle('active');
                    if (navMenu.classList.contains('active')) {
                        mobileBtn.innerText = '✖'; // Silang saat terbuka
                    } else {
                        mobileBtn.innerText = '☰'; // Garis tiga saat tertutup
                    }
                });
            }

            // PENCARIAN
            const searchInput = document.getElementById('searchInput') as HTMLInputElement;
            const appItems = document.querySelectorAll('.app-item') as NodeListOf<HTMLElement>;
            if (searchInput) {
                searchInput.addEventListener('input', (e) => {
                    const target = e.target as HTMLInputElement;
                    const term = target.value.toLowerCase();
                    appItems.forEach(item => {
                        const title = item.getAttribute('data-title') || '';
                        item.style.display = title.includes(term) ? 'flex' : 'none';
                    });
                });
            }

            // ADBLOCK
            async function checkAdBlock() {
                let isBlocked = false;
                try { await fetch(new Request('https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js'), { mode: 'no-cors' }).catch(() => isBlocked = true); } 
                catch (e) { isBlocked = true; }
                if (isBlocked) {
                    const gate = document.getElementById('ab-gate');
                    if (gate) gate.style.display = 'block';
                    document.body.style.overflow = 'hidden';
                }
            }
            checkAdBlock();
        });
    </script>
</body>
</html>