---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

// Mengambil data dari koleksi "aplikasi" dan membalik urutannya (terbaru di atas)
const allApps = await getCollection('aplikasi');
const sortedApps = allApps.reverse();
---

<Layout title="Berbagi Aplikasi - Download Software Gratis Terlengkap">
	<main class="container">
		<header class="header">
			<a href="/" class="logo">🚀 Berbagi Aplikasi</a>
			<input type="text" id="searchInput" class="search-bar" placeholder="Cari software idamanmu...">
		</header>

		<div class="ad-banner">
			<p class="ad-label">ADVERTISING</p>
			<div id="ad-native-top">
				</div>
		</div>

		<div class="app-grid" id="appGrid">
			{sortedApps.map(app => (
				<a href={`/${app.id}`} class="app-card" data-title={app.data.title.toLowerCase()}>
					<img src={app.data.gambar} alt={app.data.title} class="app-icon" />
					<div class="app-info">
						<h2 class="app-title">{app.data.title}</h2>
						<p class="app-meta">{app.data.kategori} • {app.data.os}</p>
					</div>
				</a>
			))}
		</div>
	</main>
</Layout>

<style>
	/* CSS KEMBALI BERSIH, SIMPEL, DAN LUAS */
	.container { 
		max-width: 1000px; 
		margin: 0 auto; 
		padding: 30px 20px; 
	}

	.header { 
		display: flex; 
		justify-content: space-between; 
		align-items: center; 
		margin-bottom: 40px; 
		flex-wrap: wrap; 
		gap: 20px; 
		border-bottom: 2px solid #1a1a2e;
		padding-bottom: 20px;
	}
	
	.logo { 
		color: #e94560; 
		font-size: 1.8rem; 
		font-weight: bold; 
		text-decoration: none; 
	}

	.search-bar { 
		padding: 12px 20px; 
		border-radius: 10px; 
		border: 1px solid #1a1a2e; 
		width: 100%; 
		max-width: 350px; 
		background: #16213e; 
		color: white; 
		font-size: 1rem;
		transition: 0.3s;
	}
	.search-bar:focus {
		outline: none;
		border-color: #e94560;
		box-shadow: 0 0 10px rgba(233, 69, 96, 0.3);
	}
	
	/* LAYOUT GRID UTAMA */
	.app-grid { 
		display: grid; 
		grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); 
		gap: 25px; 
	}
	
	.app-card { 
		background: #16213e; 
		padding: 25px 20px; 
		border-radius: 15px; 
		text-align: center; 
		text-decoration: none; 
		transition: 0.3s; 
		border: 1px solid transparent;
	}
	.app-card:hover { 
		transform: translateY(-8px); 
		border-color: #e94560;
		box-shadow: 0 10px 20px rgba(0,0,0,0.3);
	}
	
	.app-icon { 
		width: 90px; 
		height: 90px; 
		border-radius: 20px; 
		margin-bottom: 15px; 
		object-fit: cover; 
	}
	
	.app-title { 
		font-size: 1.2rem; 
		margin: 0 0 8px 0; 
		color: #fff; 
	}
	
	.app-meta { 
		font-size: 0.9rem; 
		margin: 0; 
		color: #8ea1c3; 
		font-weight: 500;
	}

	/* IKLAN */
	.ad-banner { 
		text-align: center; 
		margin-bottom: 30px; 
		background: rgba(255,255,255,0.02);
		padding: 10px;
		border-radius: 10px;
	}
	.ad-label { 
		font-size: 10px; 
		color: #666; 
		margin-bottom: 5px; 
		letter-spacing: 2px;
	}

	/* RESPONSIVE UNTUK HP */
	@media (max-width: 600px) {
		.header { flex-direction: column; text-align: center; }
		.search-bar { max-width: 100%; }
		.app-grid { grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 15px; }
		.app-card { padding: 15px; }
		.app-icon { width: 70px; height: 70px; }
	}
</style>

<script>
	// Script Pencarian Real-time tetap aktif!
	document.getElementById('searchInput')?.addEventListener('input', (e) => {
		const searchTerm = (e.target as HTMLInputElement).value.toLowerCase();
		const cards = document.querySelectorAll('.app-card');
		
		cards.forEach(card => {
			const title = card.getAttribute('data-title');
			if (title?.includes(searchTerm)) {
				(card as HTMLElement).style.display = 'block';
			} else {
				(card as HTMLElement).style.display = 'none';
			}
		});
	});
</script>