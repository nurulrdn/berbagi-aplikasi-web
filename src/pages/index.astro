---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content'; 

// Reverse agar aplikasi terbaru muncul paling atas
const daftarAplikasi = (await getCollection('aplikasi')).reverse();
const semuaKategori = [...new Set(daftarAplikasi.map((app: CollectionEntry<'aplikasi'>) => app.data.kategori))];
---

<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Berbagi Aplikasi - Download Software Gratis</title>
    
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f8fafc; margin: 0; padding: 0; color: #334155; }
        .navbar { 
            background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 100%);
            padding: 15px 40px; border-bottom: 1px solid rgba(255,255,255,0.1);
            display: flex; justify-content: space-between; align-items: center; 
            position: sticky; top: 0; z-index: 100; box-shadow: 0 10px 25px -5px rgba(37, 99, 235, 0.2); 
        }
        .brand { display: flex; align-items: center; gap: 12px; text-decoration: none; }
        .brand-logo { width: 32px; height: 32px; border-radius: 8px; object-fit: contain; background-color: white; padding: 2px;}
        .brand-text { margin: 0; font-size: 22px; font-weight: 800; color: #ffffff; letter-spacing: -0.5px; }
        .nav-menu { display: flex; gap: 15px; align-items: center; }
        .nav-link { text-decoration: none; color: #cbd5e1; font-weight: 600; font-size: 14px; padding: 10px 18px; border-radius: 12px; transition: all 0.3s; }
        .nav-link:hover, .nav-link.active { background-color: rgba(255,255,255,0.15); color: #ffffff; }
        .nav-btn-special { background: linear-gradient(135deg, #14b8a6, #0d9488); color: white; padding: 10px 20px; border-radius: 12px; text-decoration: none; font-weight: 700; font-size: 14px; transition: transform 0.3s, box-shadow 0.3s; }
        .nav-btn-special:hover { transform: translateY(-2px); box-shadow: 0 4px 12px rgba(20, 184, 166, 0.4); color: white;}
        .search-bar { padding: 12px 20px; width: 260px; border: 1px solid rgba(255,255,255,0.2); border-radius: 25px; outline: none; background-color: rgba(255,255,255,0.05); color: white; font-family: 'Inter', sans-serif; font-size: 14px; transition: all 0.3s; }
        .search-bar::placeholder { color: #94a3b8; }
        .search-bar:focus { border-color: #60a5fa; background-color: rgba(255,255,255,0.15); box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.2); }
        .main-layout { display: flex; max-width: 1100px; margin: 30px auto; padding: 0 20px; gap: 40px; }
        .hero-banner { background: linear-gradient(135deg, #eff6ff 0%, #e0f2fe 100%); border: 1px solid #bfdbfe; border-radius: 20px; padding: 35px 40px; margin-bottom: 35px; display: flex; flex-direction: column; justify-content: center; box-shadow: 0 4px 15px -3px rgba(37, 99, 235, 0.05); }
        .hero-title { margin: 0 0 10px 0; font-size: 26px; font-weight: 800; color: #1e3a8a; }
        .hero-desc { margin: 0; color: #475569; font-size: 16px; line-height: 1.6; max-width: 600px; }
        .sidebar { width: 220px; flex-shrink: 0; }
        .menu-title { font-size: 12px; color: #64748b; font-weight: 800; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 15px; }
        .menu-list { list-style: none; padding: 0; margin: 0 0 35px 0; }
        .menu-list li { margin-bottom: 6px; }
        .menu-list a { text-decoration: none; color: #475569; display: block; padding: 10px 14px; border-radius: 8px; font-weight: 600; font-size: 15px; transition: all 0.2s;}
        .menu-list a:hover { background-color: #eff6ff; color: #2563eb; transform: translateX(5px); }
        .content { flex-grow: 1; }
        .section-title { margin-top: 0; margin-bottom: 24px; font-size: 22px; font-weight: 800; color: #0f172a; }
        .list-layout { display: flex; flex-direction: column; gap: 20px; }
        .app-item { background-color: #ffffff; border-radius: 16px; padding: 20px; border: 1px solid #f1f5f9; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.03); text-decoration: none; display: flex; align-items: flex-start; gap: 24px; transition: all 0.3s; }
        .app-item:hover { transform: translateY(-3px); border-color: #bfdbfe; box-shadow: 0 10px 15px -3px rgba(37,99,235,0.1); }
        .app-image { width: 90px; height: 90px; object-fit: cover; border-radius: 16px; flex-shrink: 0; }
        .app-text-block { display: flex; flex-direction: column; flex-grow: 1; }
        .app-category { align-self: flex-start; font-size: 11px; color: #0284c7; background-color: #e0f2fe; font-weight: 700; padding: 4px 10px; border-radius: 20px; margin-bottom: 10px; }
        .app-title { font-size: 19px; color: #0f172a; font-weight: 700; margin: 0 0 8px 0; }
        .app-desc { font-size: 14.5px; color: #475569; margin: 0 0 16px 0; line-height: 1.6; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;}
        .app-meta { display: flex; gap: 15px; font-size: 13px; color: #64748b; font-weight: 600; align-items: center; }
        .meta-tag { background-color: #f1f5f9; padding: 5px 12px; border-radius: 8px; color: #334155; border: 1px solid #e2e8f0; }
        .no-results { display: none; text-align: center; padding: 40px; background-color: white; border-radius: 16px; border: 1px dashed #cbd5e1; color: #64748b; font-weight: 600; font-size: 16px;}
    </style>
</head>
<body>
    <div class="navbar">
        <a href="/" class="brand">
            <img src="/logo.png" alt="Logo" class="brand-logo" onerror="this.src='https://placehold.co/40x40/2563eb/white?text=BA'">
            <h1 class="brand-text">Berbagi Aplikasi</h1>
        </a>
       <div class="nav-menu">
    <a href="/" class="nav-link">Home</a>
    <a href="/jelajahi" class="nav-link">Jelajahi</a>
    <a href="/request" class="nav-btn-special">📝 Request Software</a>
    </div>
            <input type="text" id="searchInput" class="search-bar" placeholder="Cari software...">
        </div>
    </div>

    <div class="main-layout">
        <div class="sidebar">
            <div class="menu-title">Sistem Operasi</div>
            <ul class="menu-list">
                <li><a href="#">Windows</a></li>
                <li><a href="#">macOS</a></li>
                <li><a href="#">Linux</a></li>
            </ul>
            <div class="menu-title" style="margin-top: 25px;">Kategori Utama</div>
            <ul class="menu-list">
                {semuaKategori.map((kategori) => (
                    <li><a href="#">{kategori}</a></li>
                ))}
            </ul>
        </div>

        <div class="content">
            <div class="hero-banner">
                <h2 class="hero-title">Temukan Software PC Terbaik</h2>
                <p class="hero-desc">Pusat unduhan aplikasi gratis yang aman dan mudah di-instal.</p>
            </div>
            <h2 class="section-title">Update Terbaru</h2>
            <div class="list-layout" id="appList">
                {daftarAplikasi.map((app: CollectionEntry<'aplikasi'>) => (
                    <a href={'/' + app.id} class="app-item" data-title={app.data.title.toLowerCase()}>
                        <img src={app.data.gambar || 'https://placehold.co/100x100/ccc/white?text=Ikon'} alt={app.data.title} class="app-image">
                        <div class="app-text-block">
                            <div class="app-category">{app.data.kategori}</div>
                            <h3 class="app-title">{app.data.title}</h3>
                            <p class="app-desc">{app.data.ringkasan}</p>
                            <div class="app-meta">
                                <span class="meta-tag">{app.data.os}</span>
                                <span>{app.data.ukuran}</span>
                            </div>
                        </div>
                    </a>
                ))}
                <div id="noResults" class="no-results">Maaf, aplikasi tidak ditemukan. 😢</div>
            </div>
        </div>
    </div>

    <script>
        // SCRIPT PENCARIAN
        document.addEventListener('DOMContentLoaded', () => {
            const searchInput = document.getElementById('searchInput') as HTMLInputElement;
            const appItems = document.querySelectorAll('.app-item') as NodeListOf<HTMLElement>;
            const noResults = document.getElementById('noResults') as HTMLElement;
            if (searchInput) {
                searchInput.addEventListener('input', (e) => {
                    const target = e.target as HTMLInputElement;
                    const searchTerm = target.value.toLowerCase();
                    let matchCount = 0;
                    appItems.forEach(item => {
                        const title = item.getAttribute('data-title') || '';
                        if (title.includes(searchTerm)) {
                            item.style.display = 'flex';
                            matchCount++;
                        } else {
                            item.style.display = 'none';
                        }
                    });
                    noResults.style.display = matchCount === 0 ? 'block' : 'none';
                });
            }
        });
    </script>
</body>
</html>